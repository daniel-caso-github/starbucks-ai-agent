# Application
NODE_ENV=development
PORT=3000

# MongoDB
# Use 'localhost' for local development (pnpm run chat/dev)
# Use 'mongodb' for Docker (docker-compose up)
MONGO_URI=mongodb://localhost:27017/starbucks_agent

# ChromaDB
# Use 'localhost' for local development, 'chromadb' for Docker
CHROMA_HOST=http://localhost:8000

# Redis
# Use 'localhost' for local development, 'redis' for Docker
REDIS_URL=redis://localhost:6379

# Gemini AI (conversational agent - primary)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenAI (embeddings for semantic search)
OPENAI_API_KEY=your_openai_api_key_here

# OpenTelemetry (tracing)
OTEL_ENABLED=false
# For Docker use http://jaeger:4318 (already set in docker-compose.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318